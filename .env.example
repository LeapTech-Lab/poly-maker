# Polymarket authentication.
# 必填：PK 和钱包地址。FUNDER_ADDRESS / BROWSER_ADDRESS 填同一个 Polymarket 钱包地址即可。
PK=your_private_key_here
FUNDER_ADDRESS=your_polymarket_wallet_address
BROWSER_ADDRESS=your_polymarket_wallet_address
SIGNATURE_TYPE=2

# Optional: provide existing L2 creds. If omitted, the bot derives them with PK.
CLOB_API_KEY=
CLOB_SECRET=
CLOB_PASS_PHRASE=

# CLOB / chain
POLYMARKET_CLOB_HOST=https://clob.polymarket.com
CHAIN_ID=137

# Market selection.
# 不知道怎么找就运行：uv run python discover_markets.py --sports-only --limit 20
# MARKET_SOURCE=env 使用下方手动配置；MARKET_SOURCE=google_sheet 从表格读；MARKET_SOURCE=auto_rewards 自动选 rewards 市场。
MARKET_SOURCE=env
GOOGLE_SHEET_WORKSHEET=Selected Markets
GOOGLE_SHEET_LIMIT=5
CONDITION_ID=
TOKEN_ID_YES=
TOKEN_ID_NO=
AUTO_SELECT_REWARD_MARKET=false
PREFER_SPORTS=true

# Small-account strategy knobs
DRY_RUN=true
PRICE_SPREAD_BPS=120
ORDER_NOTIONAL_USDC=5
REFRESH_INTERVAL_SECONDS=8
MIN_PRICE=0.03
MAX_PRICE=0.97

# Risk limits for about 100 USDC bankroll
MAX_MARKET_EXPOSURE_USDC=25
MAX_TOKEN_EXPOSURE_USDC=30
MAX_GLOBAL_EXPOSURE_USDC=80
COUNT_EXISTING_POSITIONS_IN_GLOBAL_LIMIT=false
INVENTORY_SKEW_THRESHOLD_USDC=18
INVENTORY_SKEW_BPS=60
STOP_LOSS_PCT=12
TAKE_PROFIT_PCT=8
MAX_MARKET_LOSS_USDC=8
MAX_MIDPOINT_MOVE_BPS=350
CLOSE_ONLY_HOURS_BEFORE_END=24
RISK_OFF_AFTER_STOP=true

# Order behavior
CANCEL_ON_START=true
POST_ONLY=true
LOG_FILE=logs/market_maker.log

# Legacy Google Sheets config used by the original repository scripts.
SPREADSHEET_URL=https://docs.google.com/spreadsheets/d/your_sheet_id/edit
# SPREADSHEET_URL=https://docs.google.com/spreadsheets/d/1HDgbEaaIMnWlRKloIa83OLn6JVgvn1VmC9Hi4_pUEOk/edit?gid=1884499063#gid=1884499063
